# AI Office Core — Environment Variables
# Copy this to .env and fill in your values.

# Application
AOC_APP_NAME=AI Office Core
AOC_DEBUG=true
AOC_ENVIRONMENT=development

# PostgreSQL
AOC_POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_office_core
AOC_POSTGRES_POOL_MIN=2
AOC_POSTGRES_POOL_MAX=10

# Redis
AOC_REDIS_DSN=redis://localhost:6379/0

# NATS
AOC_NATS_URL=nats://localhost:4222

# Qdrant
AOC_QDRANT_URL=http://localhost:6333

# Auth (change in production!)
AOC_JWT_SECRET=change-me-in-production
AOC_RATE_LIMIT_PER_MINUTE=60

# Logging
AOC_LOG_LEVEL=INFO
AOC_JSON_LOGS=true
