# =============================================================================
# Company Simulator — Environment Variables (.env.example)
# Copy to .env and adjust for your local setup:
#   cp .env.example .env
# =============================================================================

# ─── General ─────────────────────────────────────────────────────────────
PROJECT_NAME=Company Simulator
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# ─── API ─────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
CORS_ORIGINS=["*"]
SECRET_KEY=change-me-to-a-random-64-char-string

# ─── PostgreSQL ──────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=company_simulator
POSTGRES_USER=cs_user
POSTGRES_PASSWORD=cs_dev_pass
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ─── Redis ───────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# ─── NATS ────────────────────────────────────────────────────────────────
NATS_HOST=localhost
NATS_CLIENT_PORT=4222
NATS_HTTP_PORT=8222
NATS_URL=nats://${NATS_HOST}:${NATS_CLIENT_PORT}

# ─── Neo4j ───────────────────────────────────────────────────────────────
NEO4J_HOST=localhost
NEO4J_BOLT_PORT=7687
NEO4J_HTTP_PORT=7474
NEO4J_AUTH=neo4j/cs_dev_pass
NEO4J_PAGECACHE=512M
NEO4J_HEAP=1G
NEO4J_BOLT_URL=bolt://${NEO4J_HOST}:${NEO4J_BOLT_PORT}
NEO4J_URI=neo4j://${NEO4J_HOST}:${NEO4J_BOLT_PORT}

# ─── Qdrant ──────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://${QDRANT_HOST}:${QDRANT_PORT}
QDRANT_API_KEY=
QDRANT_LOG_LEVEL=INFO

# ─── AI / LLM ────────────────────────────────────────────────────────────
LITELLM_PROXY_URL=http://localhost:4000
LLM_DEFAULT_MODEL=claude-sonnet-4-6
LLM_CHEAP_MODEL=claude-haiku-4-5
LLM_REASONING_MODEL=claude-opus-4-8

# API Keys (set these in your .env — never commit real keys)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# ─── Sentry / Monitoring ─────────────────────────────────────────────────
# SENTRY_DSN=https://...

# ─── Simulation ──────────────────────────────────────────────────────────
SIM_TICK_INTERVAL_SECONDS=5
SIM_MAX_COMPANIES=100

# ─── Storage ─────────────────────────────────────────────────────────────
# MinIO / S3-compatible
# STORAGE_ENDPOINT=http://localhost:9000
# STORAGE_ACCESS_KEY=minioadmin
# STORAGE_SECRET_KEY=minioadmin
# STORAGE_BUCKET=company-simulator-exports
