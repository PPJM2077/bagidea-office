#!/bin/bash
set -euo pipefail

# Resolve the project's own venv so the gate works on any machine, not just
# one where ruff/python happen to be on PATH. Falls back to `python` if no venv.
if [ -x ".venv/Scripts/python.exe" ]; then
  PY=".venv/Scripts/python.exe"
elif [ -x ".venv/bin/python" ]; then
  PY=".venv/bin/python"
else
  PY="python"
fi

echo "=== pre-commit: Running ruff check ==="
"$PY" -m ruff check .
echo "=== pre-commit: Running ruff format ==="
"$PY" -m ruff format .
echo "pre-commit checks passed."
